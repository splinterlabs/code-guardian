{
  "_comment": "Template for creating standardized MISP events. Replace placeholder values.",
  "Event": {
    "info": "Incident: <Brief description of the event>",
    "distribution": "0",
    "threat_level_id": "2",
    "analysis": "0",
    "Tag": [
      {"name": "tlp:amber"},
      {"name": "type:incident"}
    ],
    "Attribute": [
      {
        "type": "ip-dst",
        "value": "<destination IP>",
        "category": "Network activity",
        "to_ids": true,
        "comment": "C2 server / malicious endpoint"
      },
      {
        "type": "domain",
        "value": "<malicious domain>",
        "category": "Network activity",
        "to_ids": true,
        "comment": "Observed in DNS queries"
      },
      {
        "type": "url",
        "value": "hxxp://<defanged URL>",
        "category": "Network activity",
        "to_ids": true,
        "comment": "Malware distribution URL"
      },
      {
        "type": "sha256",
        "value": "<file hash>",
        "category": "Payload delivery",
        "to_ids": true,
        "comment": "Malicious file hash"
      },
      {
        "type": "email-src",
        "value": "<sender@domain>",
        "category": "Payload delivery",
        "to_ids": false,
        "comment": "Phishing sender"
      },
      {
        "type": "text",
        "value": "<free-text description of observations>",
        "category": "Other",
        "to_ids": false,
        "comment": "Investigation notes"
      }
    ]
  }
}
